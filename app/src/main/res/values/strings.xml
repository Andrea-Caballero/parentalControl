         APP INFO
         ================================================================ -->
    <string name="app_name">Control Parental</string>
    <string name="app_purpose">Ayuda a tu familia a usar dispositivos de forma segura</string>
    
    <!-- Accessibility Service -->
    <string name="accessibility_service_description">Control Parental monitorea el uso de apps para ayudarte a mantener hábitos saludables</string>
    
    <!-- Device Admin -->
    <string name="device_admin_description">Permite bloquear el dispositivo cuando sea necesario para mantener hábitos saludables</string>
    
    <!-- ================================================================
         DISCLOSURE - Divulgación Prominente (REQUIRED BY PLAY STORE)
         ================================================================ -->
    
    <!-- Título principal de la divulgación -->
    <string name="disclosure_title">Cómo funciona esta app</string>
    <string name="disclosure_title_alt">Entendiendo el Control Parental</string>
    
    <!-- Subtítulo -->
    <string name="disclosure_subtitle">Esta app necesita tu permiso para ayudarte</string>
    <string name="disclosure_subtitle_alt">Lo que necesitas saber antes de empezar</string>
    
    <!-- Punto 1: Qué hace esta app -->
    <string name="disclosure_point1_title">📱 Monitorea el uso de apps</string>
    <string name="disclosure_point1_desc">Ve qué apps usa tu hijo y cuánto tiempo pasa en cada una. Esto incluye saber qué apps están abiertas y activas.</string>
    
    <!-- Punto 2: Acceso de accesibilidad -->
    <string name="disclosure_point2_title">👁️ Usa acceso de accesibilidad</string>
    <string name="disclosure_point2_desc">Para bloquear apps y mostrar avisos, esta app usa el permiso de Accesibilidad de Android. Esto permite detectar qué apps están en uso y actuar sobre ellas.</string>
    
    <!-- Punto 3: Qué información se comparte -->
    <string name="disclosure_point3_title">📤 Comparte información con tus padres</string>
    <string name="disclosure_point3_desc">Los datos de uso se guardan de forma segura y solo son visibles para tu familia. Nadie más puede ver esta información.</string>
    
    <!-- Punto 4: Sin modo oculto -->
    <string name="disclosure_point4_title">🔓 Siempre visible</string>
    <string name="disclosure_point4_desc">Esta app no tiene modo oculto. Siempre sabrás que está funcionando. Tú también puedes ver qué se comparte con tus padres.</string>
    
    <!-- Punto 5: Tus derechos -->
    <string name="disclosure_point5_title">✅ Tú decides</string>
    <string name="disclosure_point5_desc">Puedes pedir tiempo extra, reportar problemas y tus padres pueden ajustar o desactivar los controles en cualquier momento.</string>
    
    <!-- Consentimiento afirmativo -->
    <string name="disclosure_consent_title">¿Entiendes cómo funciona?</string>
    <string name="disclosure_consent_question">¿Aceptas que esta app monitoree el uso del dispositivo para ayudarte a mantener hábitos saludables?</string>
    <string name="disclosure_consent_yes">Sí, acepto</string>
    <string name="disclosure_consent_no">No, gracias</string>
    <string name="disclosure_consent_note">Si no aceptas, la app no podrá funcionar. Puedes cambiar esta opción más adelante.</string>
    
